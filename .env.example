# Ollama base URL (default: http://localhost:11434)
# Change this to point at a remote Ollama instance, e.g. http://192.168.1.10:11434
OLLAMA_URL=http://localhost:11434

# Ollama model to use for all six hat agents (default: llama3)
# Any model available in your Ollama installation works, e.g. mistral, gemma2, phi3
OLLAMA_MODEL=llama3
